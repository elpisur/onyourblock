# Base URL of the On Your Block backend API. Vite injects this into the
# bundle at build time — names MUST start with VITE_ for Vite to expose
# them to client code (process.env.VITE_FOO becomes import.meta.env.VITE_FOO).
# Local dev: copy to .env.local (gitignored) and edit if you need a different
# host. Production: configure in Vercel → Project Settings → Environment
# Variables, scoped to "Production" (and "Preview" if you want PR previews
# to hit the same API).
VITE_API_BASE_URL=https://onyourblock-api-production.up.railway.app
